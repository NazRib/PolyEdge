+def _is_reasoning_model(model_name: str) -> bool:
+    """
+    Reasoning / 'pro' models don't support temperature, top_p, or
+    similar sampling params.  Detect them by name pattern.
+    """
+    m = model_name.lower()
+    if m.startswith(("o1", "o3")):
+        return True
+    if "-pro" in m:
+        return True
+    if "reasoning" in m:
+        return True
+    return False
 
 
